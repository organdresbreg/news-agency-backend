# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Provider Settings (openai, groq, google)
LLM_PROVIDER=groq  # Change this to switch providers

# OpenAI API Key (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY="your-openai-api-key"

# Groq API Key (only needed if LLM_PROVIDER=groq) - Free tier available
GROQ_API_KEY="your-groq-api-key"

# Google AI Studio API Key (only needed if LLM_PROVIDER=google) - Free tier available
GOOGLE_API_KEY="your-google-api-key"

# LLM Settings
DEFAULT_LLM_MODEL=llama-3.1-8b-instant  # Use appropriate model for your provider
DEFAULT_LLM_TEMPERATURE=0.2

# Long-term Memory Settings
LONG_TERM_MEMORY_PROVIDER=groq  # Can be different from main LLM provider
LONG_TERM_MEMORY_MODEL=llama-3.1-8b-instant

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Profiling Settings
PROFILING_DIR=/tmp/fastapi_profiles
PROFILING_THRESHOLD_SECONDS=2.0

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
